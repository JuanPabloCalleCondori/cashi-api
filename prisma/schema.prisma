generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  transactions Transaction[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String
  description String?
  date        DateTime
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}
